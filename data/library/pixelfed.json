{
    "name": "Pixelfed",
    "image": "pixelfed/pixelfed:v0.12",
    "category": "Social",
    "isStack": true,
    "logo": "pixelfed",
    "description": "Federated photo sharing platform (Instagram-like). Federates with Mastodon, supports stories, filters, and collections.",
    "default_ports": [
        "8080:80"
    ],
    "env_vars": {
        "DB_HOST": "postgres",
        "DB_PORT": "5432",
        "DB_DATABASE": "pixelfed",
        "DB_USERNAME": "pixelfed",
        "DB_PASSWORD": "password",
        "REDIS_HOST": "redis",
        "ADMIN_EMAIL": "admin@example.com"
    },
    "related_services": [
        {
            "name": "postgres",
            "description": "PostgreSQL database for Pixelfed",
            "category": "Database",
            "image": "postgres:15-alpine",
            "logo": "postgresql",
            "env_vars": {
                "POSTGRES_DB": "pixelfed",
                "POSTGRES_USER": "pixelfed",
                "POSTGRES_PASSWORD": "password"
            },
            "volumes": [
                "pixelfed_db:/var/lib/postgresql/data"
            ]
        },
        {
            "name": "redis",
            "description": "Redis cache for Pixelfed",
            "category": "Cache",
            "image": "redis:7-alpine",
            "logo": "redis",
            "volumes": [
                "pixelfed_redis:/data"
            ]
        }
    ]
}