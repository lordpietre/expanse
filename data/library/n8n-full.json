{
    "name": "n8n (Full Stack)",
    "description": "Powerful workflow automation tool pre-configured with PostgreSQL for execution history and Redis for high-performance scaling.",
    "category": "Automation",
    "isStack": true,
    "image": "n8nio/n8n:latest",
    "logo": "https://img.icons8.com/color/512/n8n.png",
    "default_ports": [
        "5678:5678"
    ],
    "env_vars": {
        "DB_TYPE": "postgresdb",
        "DB_POSTGRESDB_HOST": "db",
        "DB_POSTGRESDB_PORT": "5432",
        "DB_POSTGRESDB_DATABASE": "n8n",
        "DB_POSTGRESDB_USER": "n8n",
        "DB_POSTGRESDB_PASSWORD": "password",
        "QUEUE_BULL_REDIS_HOST": "redis",
        "N8N_ENCRYPTION_KEY": "expanse-secure-key",
        "N8N_SECURE_COOKIE": "false"
    },
    "volumes": [
        "n8n_data:/home/node/.n8n"
    ],
    "related_services": [
        {
            "name": "db",
            "description": "PostgreSQL database for n8n",
            "category": "Database",
            "image": "postgres:18-alpine",
            "logo": "https://img.icons8.com/color/512/postgreesql.png",
            "env_vars": {
                "POSTGRES_DB": "n8n",
                "POSTGRES_USER": "n8n",
                "POSTGRES_PASSWORD": "password"
            },
            "volumes": [
                "n8n_db_data:/var/lib/postgresql/data"
            ]
        },
        {
            "name": "redis",
            "description": "Redis for n8n queueing",
            "category": "Cache",
            "image": "redis:alpine",
            "logo": "https://img.icons8.com/color/512/redis.png"
        }
    ]
}