{
    "name": "Drupal (Full Stack)",
    "description": "Comprehensive Drupal installation with MariaDB database and persistence pre-configured.",
    "category": "CMS",
    "isStack": true,
    "image": "drupal:latest",
    "logo": "https://img.icons8.com/color/512/drupal.png",
    "default_ports": [
        "8081:80"
    ],
    "env_vars": {
        "DRUPAL_DB_HOST": "db",
        "DRUPAL_DB_USER": "drupal",
        "DRUPAL_DB_PASSWORD": "password",
        "DRUPAL_DB_NAME": "drupal"
    },
    "volumes": [
        "drupal_data:/var/www/html/sites",
        "drupal_modules:/var/www/html/modules",
        "drupal_themes:/var/www/html/themes"
    ],
    "related_services": [
        {
            "name": "db",
            "description": "MariaDB database for Drupal",
            "category": "Database",
            "image": "mariadb:10.6",
            "logo": "https://img.icons8.com/color/512/mariadb.png",
            "env_vars": {
                "MYSQL_ROOT_PASSWORD": "password",
                "MYSQL_DATABASE": "drupal",
                "MYSQL_USER": "drupal",
                "MYSQL_PASSWORD": "password"
            },
            "volumes": [
                "drupal_db_data:/var/lib/mysql"
            ]
        }
    ]
}