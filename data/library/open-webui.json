{
    "name": "Open WebUI",
    "image": "ghcr.io/open-webui/open-webui:main",
    "category": "AI",
    "logo": "https://img.icons8.com/color/512/open-webui.png",
    "description": "Interfaz tipo ChatGPT para Ollama u otros backends. Soporta RAG, agentes, voice, etc.",
    "default_ports": [
        "8080:8080"
    ],
    "volumes": [
        "open-webui_data:/app/backend/data"
    ],
    "env_vars": {
        "OLLAMA_BASE_URL": "http://ollama:11434"
    },
    "isStack": false
}