{
    "name": "ELK Stack (Observability)",
    "description": "Complete logging solution with Elasticsearch for search, Logstash for processing, and Kibana for visualization.",
    "category": "Monitoring",
    "isStack": true,
    "image": "docker.elastic.co/kibana/kibana:8.12.0",
    "logo": "https://img.icons8.com/color/512/kibana.png",
    "default_ports": [
        "5601:5601"
    ],
    "env_vars": {
        "ELASTICSEARCH_HOSTS": "http://elasticsearch:9200"
    },
    "related_services": [
        {
            "name": "elasticsearch",
            "description": "Search and analytics engine",
            "category": "Cloud",
            "image": "docker.elastic.co/elasticsearch/elasticsearch:8.12.0",
            "logo": "https://img.icons8.com/color/512/elasticsearch.png",
            "env_vars": {
                "discovery.type": "single-node",
                "xpack.security.enabled": "false"
            },
            "volumes": [
                "elk_es_data:/usr/share/elasticsearch/data"
            ]
        },
        {
            "name": "logstash",
            "description": "Server-side data processing pipeline",
            "category": "Cloud",
            "image": "docker.elastic.co/logstash/logstash:8.12.0",
            "logo": "https://img.icons8.com/color/512/logstash.png",
            "env_vars": {
                "ELASTICSEARCH_HOST": "elasticsearch:9200"
            }
        }
    ]
}