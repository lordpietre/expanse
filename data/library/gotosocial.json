{
    "name": "GoToSocial",
    "image": "superseriousbusiness/gotosocial:latest",
    "category": "Social",
    "logo": "https://gotosocial.org/static/logo.svg",
    "description": "Lightweight ActivityPub microblogging server. Perfect for personal or small instances, very low resource usage. Written in Go, 100% compatible with Mastodon clients.",
    "default_ports": [
        "8080:8080"
    ],
    "env_vars": {
        "GTS_HOST": "localhost:8080",
        "GTS_DB_TYPE": "postgres",
        "GTS_DB_ADDRESS": "postgres:5432",
        "GTS_DB_USER": "gotosocial",
        "GTS_DB_PASSWORD": "password",
        "GTS_DB_DATABASE": "gotosocial",
        "GTS_ACCOUNTS_ALLOW_REGISTRATION": "false"
    }
}