{
    "name": "Joomla (Full Stack)",
    "description": "Complete Joomla CMS deployment with integrated PostgreSQL and persistence.",
    "category": "CMS",
    "isStack": true,
    "image": "joomla:5-php8.1-apache",
    "logo": "https://img.icons8.com/color/512/joomla.png",
    "default_ports": [
        "8082:80"
    ],
    "env_vars": {
        "JOOMLA_DB_HOST": "db",
        "JOOMLA_DB_USER": "joomla",
        "JOOMLA_DB_PASSWORD": "password",
        "JOOMLA_DB_NAME": "joomla",
        "JOOMLA_DB_TYPE": "pgsql",
        "PHP_UPLOAD_MAX_FILESIZE": "64M",
        "PHP_POST_MAX_SIZE": "64M"
    },
    "volumes": [
        "joomla_data:/var/www/html"
    ],
    "related_services": [
        {
            "name": "db",
            "description": "PostgreSQL database for Joomla",
            "category": "Database",
            "image": "postgres:17-alpine",
            "logo": "postgresql",
            "env_vars": {
                "POSTGRES_USER": "joomla",
                "POSTGRES_PASSWORD": "password",
                "POSTGRES_DB": "joomla"
            },
            "volumes": [
                "joomla_db_data:/var/lib/postgresql/data"
            ]
        }
    ]
}