{
    "name": "Joomla (Full Stack)",
    "description": "Complete Joomla CMS deployment with integrated MariaDB and persistence.",
    "category": "CMS",
    "isStack": true,
    "image": "joomla:latest",
    "logo": "https://img.icons8.com/color/512/joomla.png",
    "default_ports": [
        "8082:80"
    ],
    "env_vars": {
        "JOOMLA_DB_HOST": "db",
        "JOOMLA_DB_USER": "joomla",
        "JOOMLA_DB_PASSWORD": "password",
        "JOOMLA_DB_NAME": "joomla"
    },
    "volumes": [
        "joomla_data:/var/www/html"
    ],
    "related_services": [
        {
            "name": "db",
            "description": "MariaDB database for Joomla",
            "category": "Database",
            "image": "mariadb:10.6",
            "logo": "https://img.icons8.com/color/512/mariadb.png",
            "env_vars": {
                "MYSQL_ROOT_PASSWORD": "password",
                "MYSQL_DATABASE": "joomla",
                "MYSQL_USER": "joomla",
                "MYSQL_PASSWORD": "password"
            },
            "volumes": [
                "joomla_db_data:/var/lib/mysql"
            ]
        }
    ]
}