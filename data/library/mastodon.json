        "-c",
        "rm -f /mastodon/tmp/pids/server.pid; ruby -e 'require \"socket\"; loop { begin; TCPSocket.new(\"postgres\", 5432); break; rescue; puts \"Waiting for postgres...\"; sleep 3; end }'; bundle exec rails db:migrate 2>/dev/null || bundle exec rails db:setup; bundle exec rails s -p 3000 -b 0.0.0.0"
