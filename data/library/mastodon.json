{
    "name": "Mastodon",
    "image": "tootsuite/mastodon:latest",
    "category": "Social",
    "logo": "https://cdn.simpleicons.org/mastodon",
    "description": "Classic federated microblogging platform. Mature with thousands of instances, excellent mobile apps, and powerful moderation tools. Heavy on resources (Ruby + Node + Postgres + Redis).",
    "default_ports": [
        "3000:3000",
        "4000:4000"
    ],
    "env_vars": {
        "DB_HOST": "postgres",
        "DB_PORT": "5432",
        "DB_USER": "mastodon",
        "DB_NAME": "mastodon",
        "DB_PASS": "password",
        "REDIS_HOST": "redis",
        "SECRET_KEY_BASE": "replace-with-random-value",
        "OTP_SECRET": "replace-with-random-value",
        "VAPID_PRIVATE_KEY": "replace-with-random-value",
        "VAPID_PUBLIC_KEY": "replace-with-random-value"
    }
}