{
    "name": "Mastodon",
    "image": "tootsuite/mastodon:latest",
    "category": "Social",
    "isStack": true,
    "logo": "/assets/mastodon.png",
    "description": "Classic federated microblogging platform. Mature with thousands of instances, excellent mobile apps, and powerful moderation tools. Heavy on resources (Ruby + Node + Postgres + Redis).",
    "default_ports": [
        "3000:3000",
        "4000:4000"
    ],
    "env_vars": {
        "DB_HOST": "postgres",
        "DB_PORT": "5432",
        "DB_USER": "mastodon",
        "DB_NAME": "mastodon",
        "DB_PASS": "password",
        "REDIS_HOST": "redis",
        "SECRET_KEY_BASE": "replace-with-random-value",
        "OTP_SECRET": "replace-with-random-value",
        "VAPID_PRIVATE_KEY": "replace-with-random-value",
        "VAPID_PUBLIC_KEY": "replace-with-random-value"
    },
    "related_services": [
        {
            "name": "postgres",
            "description": "PostgreSQL database for Mastodon",
            "category": "Database",
            "image": "postgres:15-alpine",
            "logo": "/postgresql.png",
            "env_vars": {
                "POSTGRES_DB": "mastodon",
                "POSTGRES_USER": "mastodon",
                "POSTGRES_PASSWORD": "password"
            },
            "volumes": [
                "mastodon_db:/var/lib/postgresql/data"
            ]
        },
        {
            "name": "redis",
            "description": "Redis cache for Mastodon",
            "category": "Cache",
            "image": "redis:7-alpine",
            "logo": "/redis.png",
            "volumes": [
                "mastodon_redis:/data"
            ]
        }
    ]
}