    "env_vars": {
        "APP_URL": "http://localhost:3000",
        "POSTGRES_HOST": "postgres",
        "POSTGRES_PORT": "5432",
        "POSTGRES_DATABASE": "automatisch",
        "POSTGRES_USER": "automatisch",
        "POSTGRES_PASSWORD": "password"
    }
}