{
    "name": "Apache Airflow",
    "image": "apache/airflow:2.10.0",
    "category": "Automation",
    "logo": "https://cdn.simpleicons.org/apacheairflow",
    "description": "Enterprise orchestration for data engineering and complex DAGs. Python-based, powerful scheduling, huge community. Overkill for simple tasks, ideal for ETL.",
    "default_ports": [
        "8090:8080"
    ],
    "env_vars": {
        "AIRFLOW__CORE__EXECUTOR": "CeleryExecutor",
        "AIRFLOW__DATABASE__SQL_ALCHEMY_CONN": "postgresql+psycopg2://airflow:password@postgres/airflow",
        "AIRFLOW__CELERY__RESULT_BACKEND": "db+postgresql://airflow:password@postgres/airflow",
        "AIRFLOW__CELERY__BROKER_URL": "redis://:redis@redis:6379/0",
        "AIRFLOW__CORE__FERNET_KEY": "replace-with-random-value",
        "AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION": "true",
        "AIRFLOW__CORE__LOAD_EXAMPLES": "false",
        "AIRFLOW__ADMIN__ADMIN_USER": "admin",
        "AIRFLOW__ADMIN__ADMIN_PASSWORD": "admin"
    }
}