{
    "name": "Pleroma",
    "image": "jkjoy/pleroma:latest",
    "category": "Social",
    "isStack": true,
    "logo": "pleroma",
    "description": "Ultra-lightweight microblogging platform. Extremely low resource consumption (Elixir). Can handle 10k+ users on modest hardware, ideal for Raspberry Pi or cheap VPS.",
    "default_ports": [
        "4000:4000"
    ],
    "env_vars": {
        "DB_HOST": "postgres",
        "DB_PORT": "5432",
        "DB_USER": "pleroma",
        "DB_NAME": "pleroma",
        "DB_PASS": "password",
        "REDIS_HOST": "redis",
        "PORT": "4000"
    },
    "related_services": [
        {
            "name": "postgres",
            "description": "PostgreSQL database for Pleroma",
            "category": "Database",
            "image": "postgres:15-alpine",
            "logo": "postgresql",
            "env_vars": {
                "POSTGRES_DB": "pleroma",
                "POSTGRES_USER": "pleroma",
                "POSTGRES_PASSWORD": "password"
            },
            "volumes": [
                "pleroma_db:/var/lib/postgresql/data"
            ]
        },
        {
            "name": "redis",
            "description": "Redis cache for Pleroma",
            "category": "Cache",
            "image": "redis:7-alpine",
            "logo": "redis",
            "volumes": [
                "pleroma_redis:/data"
            ]
        }
    ]
}