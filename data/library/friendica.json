{
    "name": "Friendica",
    "image": "friendica/node:stable",
    "category": "Social",
    "isStack": true,
    "logo": "/friendica.png",
    "description": "Full-featured social network (Facebook-like). Contacts, groups, events, and connection with other protocols. Connects with Mastodon, Diaspora, and older protocols.",
    "default_ports": [
        "8080:8080"
    ],
    "env_vars": {
        "MYSQL_HOST": "mariadb",
        "MYSQL_DATABASE": "friendica",
        "MYSQL_USER": "friendica",
        "MYSQL_PASSWORD": "password",
        "SITE_NAME": "Friendica",
        "ADMIN_MAIL": "admin@example.com"
    },
    "related_services": [
        {
            "name": "mariadb",
            "description": "MariaDB database for Friendica",
            "category": "Database",
            "image": "mariadb:10.11",
            "logo": "/mariadb.png",
            "env_vars": {
                "MYSQL_ROOT_PASSWORD": "password",
                "MYSQL_DATABASE": "friendica",
                "MYSQL_USER": "friendica",
                "MYSQL_PASSWORD": "password"
            },
            "volumes": [
                "friendica_db:/var/lib/mysql"
            ]
        }
    ]
}